<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nhà Sách Online Admin</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f8f9fa;
        }
        .sidebar {
            min-height: calc(100vh - 56px);
            background-color: white;
            border-right: 1px solid #dee2e6;
        }
        .nav-link {
            color: #495057;
            padding: 0.75rem 1.25rem;
        }
        .nav-link:hover {
            background-color: #f1f3f5;
        }
        .nav-link.active {
            background-color: #0d6efd;
            color: white !important;
        }
        .navbar-brand {
            font-weight: 700;
        }
        .book-img {
            width: 48px;
            height: 64px;
            object-fit: cover;
            border-radius: 4px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 flex flex-col font-sans">
    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <div class="bg-primary p-1 rounded text-white d-flex">
                    <span class="material-symbols-outlined">auto_stories</span>
                </div>
                <span>Nhà Sách Online <span class="badge bg-light text-secondary fw-normal fs-6 ms-1 border">ADMIN</span></span>
            </a>
            <button class="navbar-toggler" data-bs-target="#navbarNav" data-bs-toggle="collapse" type="button">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">Sách</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">Đơn hàng</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">Khách hàng</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <button class="btn btn-link text-secondary position-relative me-3">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                    </button>
                    <div class="d-flex align-items-center border-start ps-3">
                        <div class="text-end me-2 d-none d-sm-block">
                            <div class="fw-bold small">Admin User</div>
                            <div class="text-muted x-small" style="font-size: 0.75rem;">Quản trị viên</div>
                        </div>
                        <img alt="Avatar" class="rounded-circle" height="32" src="~/images/default-avatar.png" onerror="this.src='https://ui-avatars.com/api/?name=Admin&background=0d6efd&color=fff'" width="32" />
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse bg-white">
                <div class="position-sticky pt-3">
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                <span class="material-symbols-outlined me-2">monitoring</span> Tổng quan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                <span class="material-symbols-outlined me-2">book</span> Quản lý sách
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                                <span class="material-symbols-outlined me-2">shopping_cart</span> Đơn hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                <span class="material-symbols-outlined me-2">group</span> Khách hàng
                            </a>
                        </li>
                        <hr class="mx-3 my-3" />
                        <li class="nav-item">
                            <a class="nav-link text-danger d-flex align-items-center" asp-area="" asp-controller="Account" asp-action="Logout">
                                <span class="material-symbols-outlined me-2">logout</span> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer mt-auto py-3 bg-white border-top">
        <div class="container-fluid px-4 d-md-flex justify-content-between align-items-center text-center text-md-start">
            <span class="text-muted small">© @DateTime.Now.Year Nhà Sách Online Admin Panel. All rights reserved.</span>
            <div class="mt-2 mt-md-0">
                <a class="text-muted small text-decoration-none me-3" href="#">Hướng dẫn</a>
                <a class="text-muted small text-decoration-none me-3" href="#">Báo lỗi</a>
                <a class="text-muted small text-decoration-none" href="#">Liên hệ kỹ thuật</a>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>