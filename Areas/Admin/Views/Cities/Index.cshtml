@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.City>
@{
    ViewData["Title"] = "Quản lý Tỉnh/Thành phố";
    var search = ViewData["Search"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0">Quản lý Tỉnh/Thành phố</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i> Thêm Tỉnh/TP</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="search" name="search" value="@search" class="form-control" placeholder="Tìm Tỉnh/Thành phố..." />
        <button class="btn btn-primary">Tìm</button>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Tỉnh/TP</th><th>Phường/Xã</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.CityName</td>
                    <td>@c.Wards.Count</td>
                    <td>@(c.IsActive ? "Hoạt động" : "Ngừng")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@c.CityId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@c.CityId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa Tỉnh/TP này?')"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>