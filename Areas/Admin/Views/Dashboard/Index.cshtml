@{
    ViewData["Title"] = "Admin Dashboard";
    var totalProducts = ViewData["TotalProducts"] != null ? (int)ViewData["TotalProducts"] : 0;
    var totalOrders = ViewData["TotalOrders"] != null ? (int)ViewData["TotalOrders"] : 0;
    var totalCustomers = ViewData["TotalCustomers"] != null ? (int)ViewData["TotalCustomers"] : 0;
    var todayRevenue = ViewData["TodayRevenue"] != null ? (decimal)ViewData["TodayRevenue"] : 0m;
    var recentOrders = ViewData["RecentOrders"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Order> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Order>();
    var lowStockProducts = ViewData["LowStockProducts"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Product>();
}

<h2>Dashboard</h2>

<!-- Thống kê tổng quan -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-box-seam"></i> Sản phẩm</h5>
                <h2>@totalProducts</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cart-check"></i> Đơn hàng</h5>
                <h2>@totalOrders</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people"></i> Khách hàng</h5>
                <h2>@totalCustomers</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cash-coin"></i> Doanh thu hôm nay</h5>
                <h2>@todayRevenue.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Đơn hàng mới nhất -->
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Đơn hàng mới nhất</h5>
            </div>
            <div class="card-body">
                @if (recentOrders.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Khách hàng</th>
                                <th>Ngày</th>
                                <th>Tổng</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in recentOrders)
                            {
                                <tr>
                                    <td>#@o.OrderId</td>
                                    <td>@(o.User?.FullName ?? "-")</td>
                                    <td>@o.OrderDate.ToString("dd/MM HH:mm")</td>
                                    <td>@o.TotalAmount.ToString("N0")</td>
                                    <td><span class="badge bg-info">@o.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-primary">Xem tất cả</a>
                }
                else
                {
                    <p class="text-muted">Chưa có đơn hàng nào</p>
                }
            </div>
        </div>
    </div>

    <!-- Sản phẩm sắp hết hàng -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sản phẩm sắp hết hàng</h5>
            </div>
            <div class="card-body">
                @if (lowStockProducts.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Kho</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in lowStockProducts)
                            {
                                <tr>
                                    <td>@p.ProductName</td>
                                    <td><span class="badge bg-warning">@p.Stock</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-sm btn-primary">Xem tất cả</a>
                }
                else
                {
                    <p class="text-muted">Tất cả sản phẩm đều còn đủ hàng</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Revenue" class="btn btn-success">
        <i class="bi bi-graph-up"></i> Xem báo cáo doanh thu
    </a>
</div>
