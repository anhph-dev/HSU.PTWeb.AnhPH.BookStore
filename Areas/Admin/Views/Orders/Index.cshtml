@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentStatus = ViewData["Status"] as string ?? "";
    var fromDate = ViewData["FromDate"] as string ?? "";
    var toDate = ViewData["ToDate"] as string ?? "";
}

<h2>Quản lý đơn hàng</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Form tìm kiếm và lọc -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tìm theo email/tên..." />
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="Mới" selected="@(currentStatus == "Mới")">Mới</option>
            <option value="Đã vận chuyển" selected="@(currentStatus == "Đã vận chuyển")">Đã vận chuyển</option>
            <option value="Đã thanh toán" selected="@(currentStatus == "Đã thanh toán")">Đã thanh toán</option>
        </select>
    </div>
    <div class="col-md-2">
        <input type="date" name="fromDate" value="@fromDate" class="form-control" placeholder="Từ ngày" />
    </div>
    <div class="col-md-2">
        <input type="date" name="toDate" value="@toDate" class="form-control" placeholder="Đến ngày" />
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary w-100">
            <i class="bi bi-search"></i> Lọc
        </button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Mã</th>
                <th>Người đặt</th>
                <th>Email</th>
                <th>Ngày</th>
                <th>Tổng</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var o in Model)
                {
                    <tr>
                        <td><strong>#@o.OrderId</strong></td>
                        <td>@(o.User?.FullName ?? "-")</td>
                        <td>@(o.User?.Email ?? "-")</td>
                        <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><strong class="text-danger">@o.TotalAmount.ToString("N0") VND</strong></td>
                        <td>
                            <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@o.OrderId" />
                                <select name="status" class="form-select form-select-sm d-inline-block w-auto" onchange="if(confirm('Cập nhật trạng thái đơn hàng?')) this.form.submit();">
                                    <option value="Mới" selected="@(o.Status == "Mới")">Mới</option>
                                    <option value="Đã vận chuyển" selected="@(o.Status == "Đã vận chuyển")">Đã vận chuyển</option>
                                    <option value="Đã thanh toán" selected="@(o.Status == "Đã thanh toán")">Đã thanh toán</option>
                                </select>
                            </form>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-primary">
                                <i class="bi bi-eye"></i> Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mb-0">Không có đơn hàng nào</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@currentSearch"
                   asp-route-status="@currentStatus"
                   asp-route-fromDate="@fromDate"
                   asp-route-toDate="@toDate">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@currentSearch"
                       asp-route-status="@currentStatus"
                       asp-route-fromDate="@fromDate"
                       asp-route-toDate="@toDate">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@currentSearch"
                   asp-route-status="@currentStatus"
                   asp-route-fromDate="@fromDate"
                   asp-route-toDate="@toDate">»</a>
            </li>
        </ul>
    </nav>
}
