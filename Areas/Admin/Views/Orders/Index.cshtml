@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentStatus = ViewData["Status"] as string ?? "";
    var fromDate = ViewData["FromDate"] as string ?? "";
    var toDate = ViewData["ToDate"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800">Quản lý đơn hàng</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <!-- Form tìm kiếm và lọc -->
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-muted small mb-1">Tìm kiếm khách hàng</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Email, tên..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small mb-1">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending" selected="@(currentStatus == "Pending")">Chờ xử lý</option>
                    <option value="Processing" selected="@(currentStatus == "Processing")">Đang xử lý</option>
                    <option value="Shipped" selected="@(currentStatus == "Shipped")">Đang giao</option>
                    <option value="Completed" selected="@(currentStatus == "Completed")">Đã hoàn thành</option>
                    <option value="Cancelled" selected="@(currentStatus == "Cancelled")">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small mb-1">Từ ngày</label>
                <input type="date" name="fromDate" value="@fromDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small mb-1">Đến ngày</label>
                <input type="date" name="toDate" value="@toDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    Lọc dữ liệu
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-muted">
                <tr>
                    <th class="ps-4">MÃ ĐƠN</th>
                    <th>KHÁCH HÀNG</th>
                    <th>NGÀY ĐẶT</th>
                    <th>TỔNG TIỀN</th>
                    <th>TRẠNG THÁI</th>
                    <th class="text-end pe-4">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold">#@o.OrderId</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@(o.User?.FullName ?? "-")</div>
                                <div class="small text-muted">@(o.User?.Email ?? "-")</div>
                            </td>
                            <td>
                                <span class="text-muted">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </td>
                            <td>
                                <span class="fw-bold text-danger">@o.TotalAmount.ToString("N0") đ</span>
                            </td>
                            <td>
                                <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="d-inline mb-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@o.OrderId" />
                                    @{
                                        var selectClass = o.Status == "Completed" ? "text-success border-success bg-success bg-opacity-10" :
                                                          o.Status == "Shipped" ? "text-info border-info bg-info bg-opacity-10" : 
                                                          o.Status == "Processing" ? "text-primary border-primary bg-primary bg-opacity-10" :
                                                          o.Status == "Cancelled" ? "text-danger border-danger bg-danger bg-opacity-10" :
                                                          "text-warning border-warning bg-warning bg-opacity-10";
                                    }
                                    <select name="status" class="form-select form-select-sm d-inline-block w-auto fw-bold @selectClass" onchange="if(confirm('Bạn có chắc chắn muốn cập nhật trạng thái đơn hàng này?')) this.form.submit();">
                                        <option value="Pending" selected="@(o.Status == "Pending")" class="text-dark bg-white">Chờ xử lý</option>
                                        <option value="Processing" selected="@(o.Status == "Processing")" class="text-dark bg-white">Đang xử lý</option>
                                        <option value="Shipped" selected="@(o.Status == "Shipped")" class="text-dark bg-white">Đang giao</option>
                                        <option value="Completed" selected="@(o.Status == "Completed")" class="text-dark bg-white">Đã hoàn thành</option>
                                        <option value="Cancelled" selected="@(o.Status == "Cancelled")" class="text-dark bg-white">Đã hủy</option>
                                    </select>
                                </form>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-outline-primary shadow-sm" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-receipt text-secondary" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2 fs-5">Không tìm thấy đơn hàng nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 pt-4 pb-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-search="@currentSearch"
                           asp-route-status="@currentStatus"
                           asp-route-fromDate="@fromDate"
                           asp-route-toDate="@toDate">Trước</a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-fromDate="@fromDate"
                               asp-route-toDate="@toDate">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-search="@currentSearch"
                           asp-route-status="@currentStatus"
                           asp-route-fromDate="@fromDate"
                           asp-route-toDate="@toDate">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
