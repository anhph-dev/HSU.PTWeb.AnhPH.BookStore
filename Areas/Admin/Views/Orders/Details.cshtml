@model HSU.PTWeb.AnhPH.BookStore.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Chi tiết đơn hàng #@Model.OrderId</h2>
    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">Thông tin đơn hàng</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <p><strong><i class="bi bi-person"></i> Người đặt:</strong> @(Model.User?.FullName ?? "-")</p>
                <p><strong><i class="bi bi-envelope"></i> Email:</strong> @(Model.User?.Email ?? "-")</p>
            </div>
            <div class="col-md-6">
                <p><strong><i class="bi bi-calendar"></i> Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                @{
                    var badgeClass = Model.Status == "Completed" ? "bg-success" :
                                     Model.Status == "Shipped" ? "bg-info" : 
                                     Model.Status == "Processing" ? "bg-primary" :
                                     Model.Status == "Cancelled" ? "bg-danger" :
                                     "bg-warning text-dark";
                    
                    var badgeText = Model.Status == "Pending" ? "Chờ xử lý" :
                                    Model.Status == "Processing" ? "Đang xử lý" :
                                    Model.Status == "Shipped" ? "Đang giao" :
                                    Model.Status == "Completed" ? "Đã hoàn thành" :
                                    Model.Status == "Cancelled" ? "Đã hủy" : Model.Status;
                }
                <p><strong><i class="bi bi-tag"></i> Trạng thái:</strong> <span class="badge @badgeClass">@badgeText</span></p>
                <p><strong><i class="bi bi-cash-coin"></i> Tổng tiền:</strong> <span class="text-danger fw-bold fs-5">@Model.TotalAmount.ToString("N0") VND</span></p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Chi tiết sản phẩm</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th style="width: 130px;">Đơn giá</th>
                        <th style="width: 100px;">Số lượng</th>
                        <th style="width: 150px;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.OrderDetails)
                    {
                        var lineTotal = d.UnitPrice * d.Quantity;
                        <tr>
                            <td>
                                <strong>@(d.Product?.ProductName ?? "-")</strong>
                            </td>
                            <td>@d.UnitPrice.ToString("N0") VND</td>
                            <td class="text-center">@d.Quantity</td>
                            <td class="text-end"><strong>@lineTotal.ToString("N0") VND</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                        <td class="text-end"><strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") VND</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 mb-5">
    <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <div class="input-group" style="max-width: 400px;">
            <label class="input-group-text">Cập nhật trạng thái:</label>
            <select name="status" class="form-select">
                <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xử lý</option>
                <option value="Processing" selected="@(Model.Status == "Processing")">Đang xử lý</option>
                <option value="Shipped" selected="@(Model.Status == "Shipped")">Đang giao</option>
                <option value="Completed" selected="@(Model.Status == "Completed")">Đã hoàn thành</option>
                <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
            </select>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Cập nhật
            </button>
        </div>
    </form>
</div>
