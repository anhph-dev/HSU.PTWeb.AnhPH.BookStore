@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800">Quản lý danh mục</h2>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Thêm danh mục
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-10">
                <label class="form-label text-muted small mb-1">Tìm kiếm danh mục</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tên danh mục..." />
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">Lọc</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-muted">
                <tr>
                    <th class="ps-4">TÊN DANH MỤC</th>
                    <th>MÔ TẢ</th>
                    <th style="width: 140px;">SẢN PHẨM</th>
                    <th class="text-end pe-4" style="width: 220px;">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@c.CategoryName</td>
                            <td class="text-muted">@(string.IsNullOrWhiteSpace(c.Description) ? "—" : c.Description)</td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                    @c.Products.Count
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Details" asp-route-id="@c.CategoryId" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.CategoryId" class="btn btn-sm btn-outline-primary" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?')" title="Xóa" @(c.Products.Any() ? "disabled" : null)>
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-inbox text-secondary" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2 fs-5">Không có danh mục phù hợp.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 pt-4 pb-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Categories" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@currentSearch">Trước</a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-area="Admin" asp-controller="Categories" asp-action="Index" asp-route-page="@i" asp-route-search="@currentSearch">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Categories" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@currentSearch">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>