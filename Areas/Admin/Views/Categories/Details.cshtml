@model HSU.PTWeb.AnhPH.BookStore.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0">Chi tiết danh mục</h2>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h4 class="mb-3">@Model.CategoryName</h4>
        <p class="text-muted mb-2">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả" : Model.Description)</p>
        <p class="mb-0">
            Số sản phẩm: <span class="badge bg-primary">@Model.Products.Count</span>
        </p>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-primary">
        <i class="bi bi-pencil-square"></i> Sửa danh mục
    </a>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Danh sách danh mục</a>
</div>