@model HSU.PTWeb.AnhPH.BookStore.Models.Ward
@using HSU.PTWeb.AnhPH.BookStore.Models
@{
    ViewData["Title"] = "Thêm Phường/Xã";
    var cities = ViewData["Cities"] as IEnumerable<City> ?? Enumerable.Empty<City>();
}

<h3 class="mb-3">Thêm Phường/Xã</h3>
<div class="card shadow-sm border-0"><div class="card-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="mb-3">
        <label asp-for="CityId" class="form-label"></label>
        <select asp-for="CityId" class="form-select">
            <option value="">-- Chọn Tỉnh/TP --</option>
            @foreach (var c in cities)
            {
                <option value="@c.CityId">@c.CityName</option>
            }
        </select>
        <span asp-validation-for="CityId" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="WardName" class="form-label"></label>
        <input asp-for="WardName" class="form-control" />
        <span asp-validation-for="WardName" class="text-danger small"></span>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Hoạt động</label>
    </div>
    <button class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</form>
</div></div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }