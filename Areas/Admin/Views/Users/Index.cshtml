@using HSU.PTWeb.AnhPH.BookStore.Areas.Admin.Controllers
@model List<UserListItemViewModel>
@{ 
    ViewData["Title"] = "Quản lý người dùng"; 
    var page = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var search = ViewData["Search"]?.ToString();
    var role = ViewData["Role"]?.ToString();
    var status = ViewData["Status"]?.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 text-gray-800"><i class="bi bi-people"></i> Quản lý người dùng</h4>
    <span class="badge bg-secondary fs-6">Tổng: @ViewData["Total"] tài khoản</span>
</div>

<!-- Bộ lọc tìm kiếm -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label text-muted small mb-1">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input name="search" type="text" class="form-control"
                           placeholder="Tìm tên hoặc email..." value="@ViewData["Search"]" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small mb-1">Quyền</label>
                <select name="role" class="form-select">
                    <option value="">-- Tất cả Role --</option>
                    @{
                        var selectedRole = ViewData["Role"]?.ToString();
                    }
                    <option value="Admin"    selected="@(selectedRole == "Admin"    ? "selected" : null)">Admin</option>
                    <option value="Customer" selected="@(selectedRole == "Customer" ? "selected" : null)">Customer</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small mb-1">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">-- Trạng thái --</option>
                    @{
                        var selectedStatus = ViewData["Status"]?.ToString();
                    }
                    <option value="active" selected="@(selectedStatus == "active" ? "selected" : null)">Hoạt động</option>
                    <option value="locked" selected="@(selectedStatus == "locked" ? "selected" : null)">Bị khoá</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Lọc dữ liệu
                </button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Đặt lại
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Bảng danh sách -->
<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-muted">
                <tr>
                    <th class="ps-3">#ID</th>
                    <th>HỌ VÀ TÊN</th>
                    <th>EMAIL</th>
                    <th>ĐIỆN THOẠI</th>
                    <th>ROLE</th>
                    <th>ĐƠN HÀNG</th>
                    <th>NGÀY TẠO</th>
                    <th>TRẠNG THÁI</th>
                    <th class="text-end pe-3">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr class="@(u.IsLocked ? "bg-light" : "")">
                        <td class="text-muted small ps-3">#@u.UserId</td>
                        <td>
                            <strong>@u.FullName</strong>
                        </td>
                        <td>@u.Email</td>
                        <td>@(u.PhoneNumber ?? "—")</td>
                        <td>
                            <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-primary") bg-opacity-10 @(u.Role == "Admin" ? "text-danger" : "text-primary") border @(u.Role == "Admin" ? "border-danger-subtle" : "border-primary-subtle") rounded-pill px-3 py-2">
                                @u.Role
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@u.OrderCount đơn</span>
                        </td>
                        <td class="text-muted small">@u.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (u.IsLocked)
                            {
                                <span class="badge bg-danger"><i class="bi bi-lock-fill"></i> Bị khoá</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Hoạt động</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <div class="btn-group btn-group-sm rounded shadow-sm">
                                <a asp-action="Details" asp-route-id="@u.UserId"
                                   class="btn btn-outline-primary" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (u.IsLocked)
                                {
                                    <form asp-action="Unlock" asp-route-id="@u.UserId"
                                          method="post" class="d-inline mb-0"
                                          onsubmit="return confirm('Mở khoá tài khoản @u.Email?')">
                                        <button class="btn btn-outline-success" title="Mở khoá">
                                            <i class="bi bi-unlock"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Lock" asp-route-id="@u.UserId"
                                          method="post" class="d-inline mb-0"
                                          onsubmit="return confirm('Khoá tài khoản @u.Email?')">
                                        <input type="hidden" name="days" value="0" />
                                        <button class="btn btn-outline-warning" title="Khoá">
                                            <i class="bi bi-lock"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            Không tìm thấy người dùng nào
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 pt-4 pb-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(page - 1)" asp-route-search="@search"
                           asp-route-role="@role" asp-route-status="@status">Trước</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i" asp-route-search="@search"
                               asp-route-role="@role" asp-route-status="@status">@i</a>
                        </li>
                    }
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(page + 1)" asp-route-search="@search"
                           asp-route-role="@role" asp-route-status="@status">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
