@using HSU.PTWeb.AnhPH.BookStore.Areas.Admin.Controllers
@model List<UserListItemViewModel>
@{ ViewData["Title"] = "Quản lý người dùng"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-people"></i> Quản lý người dùng</h4>
    <span class="badge bg-secondary fs-6">Tổng: @ViewData["Total"] tài khoản</span>
</div>

{{-- Bộ lọc tìm kiếm --}}
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input name="search" type="text" class="form-control"
                       placeholder="Tìm tên hoặc email..." value="@ViewData["Search"]" />
            </div>
            <div class="col-md-2">
                <select name="role" class="form-select">
                    <option value="">-- Tất cả Role --</option>
                    @{
                        var selectedRole = ViewData["Role"]?.ToString();
                    }
                    <option value="Admin"    selected="@(selectedRole == "Admin"    ? "selected" : null)">Admin</option>
                    <option value="Customer" selected="@(selectedRole == "Customer" ? "selected" : null)">Customer</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">-- Trạng thái --</option>
                    @{
                        var selectedStatus = ViewData["Status"]?.ToString();
                    }
                    <option value="active" selected="@(selectedStatus == "active" ? "selected" : null)">Hoạt động</option>
                    <option value="locked" selected="@(selectedStatus == "locked" ? "selected" : null)">Bị khoá</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Đặt lại
                </a>
            </div>
        </form>
    </div>
</div>

{{-- Bảng danh sách --}}
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#ID</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Role</th>
                    <th>Đơn hàng</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr class="@(u.IsLocked ? "table-secondary" : "")">
                        <td class="text-muted small">#@u.UserId</td>
                        <td>
                            <strong>@u.FullName</strong>
                        </td>
                        <td>@u.Email</td>
                        <td>@(u.PhoneNumber ?? "—")</td>
                        <td>
                            <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                @u.Role
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@u.OrderCount đơn</span>
                        </td>
                        <td class="text-muted small">@u.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (u.IsLocked)
                            {
                                <span class="badge bg-danger"><i class="bi bi-lock-fill"></i> Bị khoá</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Hoạt động</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@u.UserId"
                               class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (u.IsLocked)
                            {
                                <form asp-action="Unlock" asp-route-id="@u.UserId"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Mở khoá tài khoản @u.Email?')">
                                    <button class="btn btn-sm btn-success" title="Mở khoá">
                                        <i class="bi bi-unlock"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Lock" asp-route-id="@u.UserId"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Khoá tài khoản @u.Email?')">
                                    <input type="hidden" name="days" value="0" />
                                    <button class="btn btn-sm btn-warning" title="Khoá">
                                        <i class="bi bi-lock"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            Không tìm thấy người dùng nào
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

{{-- Phân trang --}}
@{
    var page       = (int)ViewData["Page"];
    var totalPages = (int)ViewData["TotalPages"];
    var search     = ViewData["Search"]?.ToString();
    var role       = ViewData["Role"]?.ToString();
    var status     = ViewData["Status"]?.ToString();
}
@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page - 1)" asp-route-search="@search"
                   asp-route-role="@role" asp-route-status="@status">←</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i" asp-route-search="@search"
                       asp-route-role="@role" asp-route-status="@status">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page + 1)" asp-route-search="@search"
                   asp-route-role="@role" asp-route-status="@status">→</a>
            </li>
        </ul>
    </nav>
}
