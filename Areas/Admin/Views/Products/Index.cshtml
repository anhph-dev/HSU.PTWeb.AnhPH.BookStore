@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800">Quản lý sách</h2>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Thêm sách mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <!-- Form tìm kiếm và lọc -->
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label text-muted small mb-1">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tên sách, tác giả..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small mb-1">Lọc theo thể loại</label>
                <select name="categoryId" class="form-select">
                    <option value="0">Tất cả thể loại</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100">
                    Lọc kết quả
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-muted">
                <tr>
                    <th style="width: 80px;" class="ps-3">HÌNH</th>
                    <th>TÊN SÁCH / TÁC GIẢ</th>
                    <th>GIÁ</th>
                    <th>THỂ LOẠI</th>
                    <th class="text-end pe-3" style="width: 150px;">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <img src="~/images/@(p.ImageUrl ?? "products/placeholder.svg")" 
                                     class="rounded shadow-sm" style="width:50px;height:70px;object-fit:cover;" 
                                     onerror="this.src='/images/products/placeholder.svg'" />
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@p.ProductName</div>
                                <div class="small text-muted">@(!string.IsNullOrEmpty(p.Author) ? p.Author : "Chưa cập nhật")</div>
                                @if (p.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark mt-1"><i class="bi bi-star-fill"></i> Nổi bật</span>
                                }
                            </td>
                            <td>
                                @if (p.HasDiscount)
                                {
                                    <div class="text-decoration-line-through text-muted small">@p.OriginalPrice?.ToString("N0") đ</div>
                                }
                                <div class="fw-bold text-danger">@p.Price.ToString("N0") đ</div>
                            </td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                    @(p.Category?.CategoryName ?? "Không có")
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-2">

                                    <a asp-area="Admin"
                                       asp-controller="Products"
                                       asp-action="Edit"
                                       asp-route-id="@p.ProductId"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form asp-area="Admin"
                                          asp-controller="Products"
                                          asp-action="Delete"
                                          asp-route-id="@p.ProductId"
                                          method="post"
                                          class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Bạn có chắc chắn muốn xóa sách này?')"
                                                title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-inbox text-secondary" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2 fs-5">Không tìm thấy đầu sách nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (totalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 pt-4 pb-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-end mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-search="@currentSearch"
                           asp-route-categoryId="@(currentCategory)">Trước</a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@currentSearch"
                               asp-route-categoryId="@(currentCategory)">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-search="@currentSearch"
                           asp-route-categoryId="@(currentCategory)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
