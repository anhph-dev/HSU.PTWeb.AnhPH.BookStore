@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<h2>Quản lý sản phẩm</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Form tìm kiếm và lọc -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tìm theo tên sách..." />
    </div>
    <div class="col-md-3">
        <select name="categoryId" class="form-select">
            <option value="0">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100">
            <i class="bi bi-search"></i> Lọc
        </button>
    </div>
    <div class="col-md-3 text-end">
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-success w-100">
            <i class="bi bi-plus-circle"></i> Tạo sản phẩm mới
        </a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th style="width: 80px;">Ảnh</th>
                <th>Tên sách</th>
                <th>Tác giả</th>
                <th>Danh mục</th>
                <th style="width: 130px;">Giá</th>
                <th style="width: 80px;">Kho</th>
                <th style="width: 80px;">Đã bán</th>
                <th style="width: 200px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <img src="~/images/@(p.ImageUrl ?? "products/placeholder.svg")" 
                                 style="width:60px;height:80px;object-fit:cover;border-radius:5px;" 
                                 onerror="this.src='/images/products/placeholder.svg'" />
                        </td>
                        <td>
                            <strong>@p.ProductName</strong>
                            @if (!string.IsNullOrEmpty(p.ISBN))
                            {
                                <br /><small class="text-muted">ISBN: @p.ISBN</small>
                            }
                            <br />
                            @if (p.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Nổi bật</span>
                            }
                            @if (p.IsNewArrival)
                            {
                                <span class="badge bg-info"><i class="bi bi-award-fill"></i> Mới</span>
                            }
                            @if (p.IsBestSeller)
                            {
                                <span class="badge bg-danger"><i class="bi bi-fire"></i> Bán chạy</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.Author))
                            {
                                <text>@p.Author</text>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td><span class="badge bg-secondary">@(p.Category?.CategoryName ?? "-")</span></td>
                        <td>
                            @if (p.HasDiscount)
                            {
                                <span class="text-decoration-line-through text-muted small">@p.OriginalPrice?.ToString("N0")</span>
                                <br />
                            }
                            <strong class="text-danger">@p.Price.ToString("N0") VND</strong>
                            @if (p.DiscountPercent.HasValue && p.DiscountPercent.Value > 0)
                            {
                                <br /><span class="badge bg-success">-@p.DiscountPercent%</span>
                            }
                        </td>
                        <td>
                            @if (p.IsOutOfStock)
                            {
                                <span class="badge bg-danger">@p.Stock</span>
                            }
                            else if (p.IsLowStock)
                            {
                                <span class="badge bg-warning text-dark">@p.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@p.Stock</span>
                            }
                        </td>
                        <td><span class="badge bg-info">@p.SoldCount</span></td>
                        <td>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.ProductId" class="btn btn-sm btn-primary" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@p.ProductId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa sản phẩm này?')" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mb-0">Không có sản phẩm nào</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@currentSearch"
                       asp-route-categoryId="@(currentCategory)">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-area="Admin" asp-controller="Products" asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)">»</a>
            </li>
        </ul>
    </nav>
}
