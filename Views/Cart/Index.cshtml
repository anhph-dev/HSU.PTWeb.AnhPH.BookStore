@model List<HSU.PTWeb.AnhPH.BookStore.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2>Giỏ hàng</h2>
@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Giỏ hàng trống.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Sách</th>
                <th>Đơn giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="~/images/@(item.ImageUrl ?? "products/placeholder.png")" style="width:60px" /> @item.ProductName
                    </td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>
                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width:80px;" />
                            <button class="btn btn-sm btn-primary ms-2">Cập nhật</button>
                        </form>
                    </td>
                    <td>@(item.Price * item.Quantity).ToString("N0")</td>
                    <td>
                        <form asp-action="RemoveItem" method="post">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-between">
        <a asp-controller="Order" asp-action="Checkout" class="btn btn-success">Tiến hành thanh toán</a>
        <form asp-action="ClearCart" method="post">
            <button class="btn btn-secondary">Xóa giỏ</button>
        </form>
    </div>
}
