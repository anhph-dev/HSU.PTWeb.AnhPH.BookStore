@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentSort = ViewData["Sort"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<h2>Cửa hàng sách</h2>

<!-- Form tìm kiếm / lọc / sắp xếp -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tìm theo tên sách hoặc tác giả..." />
    </div>
    <div class="col-md-3">
        <select name="categoryId" class="form-select">
            <option value="0">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="sort" class="form-select">
            <option value="">Mặc định</option>
            <option value="price_asc" selected="@(currentSort == "price_asc")">Giá: thấp → cao</option>
            <option value="price_desc" selected="@(currentSort == "price_desc")">Giá: cao → thấp</option>
            <option value="newest" selected="@(currentSort == "newest")">Mới nhất</option>
            <option value="bestseller" selected="@(currentSort == "bestseller")">Bán chạy nhất</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100"><i class="bi bi-search"></i> Lọc</button>
    </div>
</form>

<div class="row">
    @foreach (var p in Model ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Product>())
    {
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card h-100 shadow-sm hover-shadow" style="transition: all 0.3s;">
                <!-- BADGES -->
                <div class="position-relative">
                    <img src="~/images/@(p.ImageUrl ?? "products/placeholder.svg")" 
                         class="card-img-top" 
                         style="height:280px;object-fit:cover;" 
                         onerror="this.src='/images/products/placeholder.svg'" 
                         alt="@p.ProductName" />
                    
                    <div class="position-absolute top-0 start-0 p-2">
                        @if (p.IsBestSeller)
                        {
                            <span class="badge bg-danger mb-1"><i class="bi bi-fire"></i> Best Seller</span>
                        }
                        @if (p.IsNewArrival)
                        {
                            <span class="badge bg-info mb-1"><i class="bi bi-award-fill"></i> Mới</span>
                        }
                    </div>

                    @if (p.HasDiscount && p.DiscountPercent.HasValue)
                    {
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-danger fs-6">-@p.DiscountPercent%</span>
                        </div>
                    }
                </div>

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title" style="min-height:48px;font-size:0.95rem;">@p.ProductName</h5>
                    
                    @if (!string.IsNullOrEmpty(p.Author))
                    {
                        <p class="text-muted small mb-2"><i class="bi bi-person"></i> @p.Author</p>
                    }

                    @if (p.AverageRating > 0)
                    {
                        <div class="mb-2">
                            <span class="text-warning small">@p.RatingStars</span>
                            <span class="text-muted small">(@p.ReviewCount)</span>
                        </div>
                    }

                    <div class="mb-2">
                        @if (p.HasDiscount)
                        {
                            <div>
                                <span class="text-decoration-line-through text-muted small">@p.OriginalPrice?.ToString("N0") VND</span>
                            </div>
                            <div>
                                <span class="text-danger fw-bold fs-5">@p.Price.ToString("N0") VND</span>
                            </div>
                        }
                        else
                        {
                            <span class="text-danger fw-bold fs-5">@p.Price.ToString("N0") VND</span>
                        }
                    </div>

                    @if (p.IsOutOfStock)
                    {
                        <span class="badge bg-danger mb-2"><i class="bi bi-x-circle"></i> Hết hàng</span>
                    }
                    else if (p.IsLowStock)
                    {
                        <span class="badge bg-warning text-dark mb-2"><i class="bi bi-exclamation-triangle"></i> Chỉ còn @p.Stock</span>
                    }

                    <div class="mt-auto d-flex gap-2">
                        <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductId" 
                           class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-eye"></i> Chi tiết
                        </a>
                        @if (!p.IsOutOfStock)
                        {
                            <a asp-area="" asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@p.ProductId" 
                               class="btn btn-sm btn-primary flex-fill">
                                <i class="bi bi-cart-plus"></i> Giỏ hàng
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary flex-fill" disabled>
                                <i class="bi bi-cart-x"></i> Hết hàng
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mb-0 mt-2">Không tìm thấy sản phẩm nào.</p>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-area="" asp-controller="Product" asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)"
                   asp-route-sort="@currentSort">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-area="" asp-controller="Product" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@currentSearch"
                       asp-route-categoryId="@(currentCategory)"
                       asp-route-sort="@currentSort">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-area="" asp-controller="Product" asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)"
                   asp-route-sort="@currentSort">»</a>
            </li>
        </ul>
    </nav>
}

@section Styles {
    <style>
        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
    </style>
}
