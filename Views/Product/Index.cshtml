@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentSort = ViewData["Sort"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<h2>Sản phẩm</h2>

<!-- Form tìm kiếm / lọc / sắp xếp -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tìm theo tên sách..." />
    </div>
    <div class="col-md-3">
        <select name="categoryId" class="form-select">
            <option value="0">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="sort" class="form-select">
            <option value="">Mặc định</option>
            <option value="price_asc" selected="@(currentSort == "price_asc")">Giá: thấp → cao</option>
            <option value="price_desc" selected="@(currentSort == "price_desc")">Giá: cao → thấp</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100">Lọc</button>
    </div>
</form>

<div class="row">
    @foreach (var p in Model ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Product>())
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100">
                <img src="~/images/@(p.ImageUrl ?? "products/placeholder.png")" class="card-img-top" style="height:220px;object-fit:cover;" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@p.ProductName</h5>
                    <p class="card-text text-danger fw-bold">@p.Price.ToString("N0") VND</p>
                    <div class="mt-auto">
                        <a asp-action="Details" asp-route-id="@p.ProductId" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@p.ProductId" class="btn btn-sm btn-primary">Thêm vào giỏ</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)"
                   asp-route-sort="@currentSort">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@currentSearch"
                       asp-route-categoryId="@(currentCategory)"
                       asp-route-sort="@currentSort">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)"
                   asp-route-sort="@currentSort">»</a>
            </li>
        </ul>
    </nav>
}
