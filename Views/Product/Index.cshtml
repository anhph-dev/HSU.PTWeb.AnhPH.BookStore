@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng sách";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentSort = ViewData["Sort"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<div class="row align-items-center mb-4 mt-3">
    <div class="col-md-4">
        <h3 class="fw-bold mb-0 text-primary"><i class="bi bi-book-half"></i> Khám phá sách</h3>
    </div>
    <div class="col-md-8">
        <form method="get" class="row g-2 justify-content-end">
            <div class="col-md-5">
                <div class="input-group shadow-sm">
                    <input type="search" name="search" value="@currentSearch" class="form-control border-0" placeholder="Tên sách, tác giả..." />
                    <button class="btn btn-white bg-white border-0 text-primary" type="submit" title="Tìm kiếm"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="col-md-4">
                <select name="categoryId" class="form-select shadow-sm border-0" onchange="this.form.submit()">
                    <option value="0">Tất cả danh mục</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select shadow-sm border-0" onchange="this.form.submit()">
                    <option value="">Sắp xếp</option>
                    <option value="price_asc" selected="@(currentSort == "price_asc")">Giá ↑</option>
                    <option value="price_desc" selected="@(currentSort == "price_desc")">Giá ↓</option>
                    <option value="newest" selected="@(currentSort == "newest")">Mới nhất</option>
                </select>
            </div>
        </form>
    </div>
</div>

<div class="row">
    @foreach (var p in Model ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Product>())
    {
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card h-100 shadow-sm border-0 rounded-3 position-relative book-card">
                <!-- BADGES -->
                <div class="position-absolute top-0 start-0 p-2 z-1">
                    @if (p.IsBestSeller)
                    {
                        <span class="badge bg-danger mb-1 shadow-sm"><i class="bi bi-fire"></i> Best Seller</span><br/>
                    }
                    @if (p.IsNewArrival)
                    {
                        <span class="badge bg-info mb-1 shadow-sm"><i class="bi bi-star"></i> Mới</span>
                    }
                </div>
                @if (p.HasDiscount && p.DiscountPercent.HasValue)
                {
                    <div class="position-absolute top-0 end-0 p-2 z-1">
                        <span class="badge bg-danger rounded-pill px-2 py-1 shadow-sm">-@p.DiscountPercent%</span>
                    </div>
                }

                <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductId" class="text-center bg-light rounded-top d-block p-3">
                    <img src="~/images/@(p.ImageUrl ?? "products/placeholder.svg")" 
                         class="img-fluid rounded shadow-sm" 
                         style="height:220px;object-fit:cover;transition: transform .3s ease;" 
                         onerror="this.src='/images/products/placeholder.svg'" 
                         alt="@p.ProductName" />
                </a>

                <div class="card-body d-flex flex-column px-3 py-3">
                    <h6 class="card-title text-dark fw-bold mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;height:42px;">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductId" class="text-decoration-none text-dark">@p.ProductName</a>
                    </h6>
                    
                    <p class="text-muted small mb-2 text-truncate"><i class="bi bi-pen"></i> @(string.IsNullOrEmpty(p.Author) ? "Đang cập nhật" : p.Author)</p>

                    <div class="mb-3 mt-auto">
                        @if (p.HasDiscount)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-danger fw-bold fs-5">@p.Price.ToString("N0")đ</span>
                                <span class="text-decoration-line-through text-muted small">@p.OriginalPrice?.ToString("N0")đ</span>
                            </div>
                        }
                        else
                        {
                            <div class="text-primary fw-bold fs-5 mb-0">@p.Price.ToString("N0")đ</div>
                        }
                    </div>

                    <div class="d-grid mt-auto gap-2">
                        @if (!p.IsOutOfStock)
                        {
                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@p.ProductId" 
                               class="btn btn-primary shadow-sm rounded-pill fw-semibold">
                                <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary rounded-pill shadow-sm" disabled>
                                <i class="bi bi-cart-x"></i> Tạm hết hàng
                            </button>
                        }
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductId" 
                           class="btn btn-outline-secondary rounded-pill">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 py-5 text-center">
            <i class="bi bi-journal-x text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">Không tìm thấy cuốn sách nào!</h4>
            <p class="text-muted">Vui lòng thử tìm kiếm bằng từ khóa khác.</p>
        </div>
    }
</div>

@if (totalPages > 1)
{
    <nav class="mt-4 mb-5">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage - 1)" asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)" asp-route-sort="@currentSort">Trước</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i" asp-route-search="@currentSearch"
                       asp-route-categoryId="@(currentCategory)" asp-route-sort="@currentSort">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage + 1)" asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)" asp-route-sort="@currentSort">Sau</a>
            </li>
        </ul>
    </nav>
}

@section Styles {
    <style>
        .book-card {
            transition: all 0.3s ease;
        }
        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
        .book-card:hover img {
            transform: scale(1.05);
        }
    </style>
}
