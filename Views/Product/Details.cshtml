@model HSU.PTWeb.AnhPH.BookStore.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
}

<nav aria-label="breadcrumb" class="my-3">
    <ol class="breadcrumb bg-transparent p-0 mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house-door"></i> Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-decoration-none">Sách</a></li>
        @if (Model.Category != null)
        {
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none">@Model.Category.CategoryName</a></li>
        }
        <li class="breadcrumb-item active text-truncate" aria-current="page" style="max-width: 200px;">@Model.ProductName</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<div class="card shadow-sm border-0 mb-5 rounded-4">
    <div class="card-body p-4 p-md-5">
        <div class="row g-5">
            <!-- Left column: Image -->
            <div class="col-md-4 text-center">
                <div class="position-relative">
                    <img src="~/images/@(Model.ImageUrl ?? "products/placeholder.svg")" 
                         class="img-fluid rounded shadow" 
                         style="max-height: 450px; object-fit: contain; width: 100%" 
                         onerror="this.src='/images/products/placeholder.svg'" 
                         alt="@Model.ProductName" />
                    
                    @if (Model.HasDiscount && Model.DiscountPercent.HasValue)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 fs-6 rounded-pill shadow-sm">
                            -@Model.DiscountPercent%
                        </span>
                    }
                </div>
            </div>

            <!-- Right column: Information -->
            <div class="col-md-8">
                <h2 class="fw-bold mb-3">@Model.ProductName</h2>
                
                <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
                    <span class="text-muted"><i class="bi bi-pen me-1"></i> Tác giả: <strong class="text-dark">@(string.IsNullOrEmpty(Model.Author) ? "Đang cập nhật" : Model.Author)</strong></span>
                    <span class="text-muted border-start ps-3"><i class="bi bi-tag me-1"></i> Thể loại: <strong class="text-dark">@(Model.Category?.CategoryName ?? "Khác")</strong></span>
                </div>

                <div class="bg-light p-4 rounded-3 mb-4">
                    @if (Model.HasDiscount)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <h2 class="text-danger fw-bold mb-0"><span id="product-total-price">@Model.Price.ToString("N0")</span> đ</h2>
                            <span class="text-decoration-line-through text-muted fs-5">@Model.OriginalPrice?.ToString("N0") đ</span>
                        </div>
                    }
                    else
                    {
                        <h2 class="text-primary fw-bold mb-0"><span id="product-total-price">@Model.Price.ToString("N0")</span> đ</h2>
                    }
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold mb-2">Thông tin ngắn gọn:</h6>
                    <p class="text-muted lh-lg" style="text-align: justify">
                        @(string.IsNullOrEmpty(Model.ShortDescription) ? "Chưa có mô tả ngắn cho sản phẩm này." : Model.ShortDescription)
                    </p>
                </div>

                <!-- Action Form -->
                <form asp-controller="Cart" asp-action="AddToCart" method="get" class="mb-4">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    
                    <div class="d-flex align-items-end gap-4 mb-4">
                        <div>
                            <label class="form-label fw-bold small text-muted mb-2">SỐ LƯỢNG</label>
                            <div class="input-group" style="width: 140px;">
                                <button class="btn btn-outline-secondary" type="button" onclick="updateQty(-1)">-</button>
                                <input type="number" id="qty" name="quantity" value="1" min="1" max="@Model.Stock" class="form-control text-center fw-bold" readonly onchange="updatePrice()" />
                                <button class="btn btn-outline-secondary" type="button" onclick="updateQty(1)">+</button>
                            </div>
                        </div>
                        <div class="pb-1 text-muted small">
                            @if (Model.IsOutOfStock)
                            {
                                <span class="text-danger fw-bold"><i class="bi bi-x-circle"></i> Đã hết hàng</span>
                            }
                            else
                            {
                                <span>(Còn @Model.Stock sản phẩm)</span>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        @if (Model.IsOutOfStock)
                        {
                            <button type="submit" class="btn btn-outline-primary btn-lg px-4 shadow-sm" disabled>
                                <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ
                            </button>
                            <button type="submit" asp-action="BuyNow" name="action" value="buy_now" class="btn btn-primary btn-lg px-5 shadow-sm fw-bold" disabled>
                                Mua ngay <i class="bi bi-arrow-right-circle ms-2"></i>
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-outline-primary btn-lg px-4 shadow-sm">
                                <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ
                            </button>
                            <button type="submit" asp-action="BuyNow" name="action" value="buy_now" class="btn btn-primary btn-lg px-5 shadow-sm fw-bold">
                                Mua ngay <i class="bi bi-arrow-right-circle ms-2"></i>
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <ul class="nav nav-tabs border-bottom-0" id="productTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold text-primary border-bottom border-primary border-3 bg-transparent" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc" type="button" role="tab">
                    MÔ TẢ CHI TIẾT
                </button>
            </li>
            <li class="nav-item ms-3" role="presentation">
                <button class="nav-link text-muted bg-transparent border-0" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button" role="tab" onclick="this.classList.add('fw-bold','text-primary','border-bottom','border-primary','border-3'); document.getElementById('desc-tab').classList.remove('fw-bold','text-primary','border-bottom','border-primary','border-3');">
                    THÔNG SỐ KỸ THUẬT
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body p-4">
        <div class="tab-content" id="productTabsContent">
            <!-- Mô tả -->
            <div class="tab-pane fade show active" id="desc" role="tabpanel">
                <div class="text-muted lh-lg" style="white-space: pre-line; text-align: justify;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả chi tiết." : Model.Description)
                </div>
            </div>
            
            <!-- Thông số -->
            <div class="tab-pane fade" id="specs" role="tabpanel">
                <table class="table table-bordered table-striped w-50 m-0">
                    <tbody>
                        <tr><th style="width: 40%" class="bg-light text-muted">Mã ISBN</th><td class="fw-bold">@(Model.ISBN ?? "-")</td></tr>
                        <tr><th class="bg-light text-muted">Nhà xuất bản</th><td>@(Model.Publisher ?? "-")</td></tr>
                        <tr><th class="bg-light text-muted">Năm xuất bản</th><td>@(Model.PublicationYear?.ToString() ?? "-")</td></tr>
                        <tr><th class="bg-light text-muted">Số trang</th><td>@(Model.PageCount?.ToString() ?? "-") trang</td></tr>
                        <tr><th class="bg-light text-muted">Ngôn ngữ</th><td>@(Model.Language ?? "-")</td></tr>
                        <tr><th class="bg-light text-muted">Hình thức bìa</th><td>@(Model.CoverType ?? "-")</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const unitPrice = @Model.Price;
        const maxStock = @Model.Stock;
        
        function updateQty(change) {
            const qtyInput = document.getElementById('qty');
            let currentVal = parseInt(qtyInput.value) || 1;
            let newVal = currentVal + change;
            
            if (newVal < 1) newVal = 1;
            if (newVal > maxStock) newVal = maxStock;
            
            qtyInput.value = newVal;
            updatePrice();
        }

        function updatePrice() {
            const qtyInput = document.getElementById('qty');
            const qty = parseInt(qtyInput.value) || 1;
            const totalPrice = unitPrice * qty;
            
            // Format number as N0 (e.g., 100,000)
            const formattedPrice = totalPrice.toLocaleString('en-US').replace(/,/g, ',');
            document.getElementById('product-total-price').innerText = formattedPrice;
        }
    </script>
}
