@model HSU.PTWeb.AnhPH.BookStore.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <!-- HÌNH ẢNH -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-0">
                <img src="~/images/@(Model.ImageUrl ?? "products/placeholder.svg")" 
                     class="img-fluid" 
                     style="width:100%;max-height:600px;object-fit:contain;" 
                     onerror="this.src='/images/products/placeholder.svg'" 
                     alt="@Model.ProductName" />
            </div>
        </div>
    </div>

    <!-- THÔNG TIN -->
    <div class="col-md-7">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Product" asp-action="Index">Trang chủ</a></li>
                @if (Model.Category != null)
                {
                    <li class="breadcrumb-item">@Model.Category.CategoryName</li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>

        <h1 class="h2 mb-2">@Model.ProductName</h1>
        
        <!-- BADGES -->
        <div class="mb-3">
            @if (Model.IsFeatured)
            {
                <span class="badge bg-warning text-dark me-1"><i class="bi bi-star-fill"></i> Nổi bật</span>
            }
            @if (Model.IsNewArrival)
            {
                <span class="badge bg-info me-1"><i class="bi bi-award-fill"></i> Hàng mới</span>
            }
            @if (Model.IsBestSeller)
            {
                <span class="badge bg-danger me-1"><i class="bi bi-fire"></i> Bán chạy</span>
            }
        </div>

        <!-- AUTHOR & RATING -->
        <div class="mb-3">
            @if (!string.IsNullOrEmpty(Model.Author))
            {
                <p class="text-muted mb-1">
                    <i class="bi bi-person-fill"></i> Tác giả: <strong>@Model.Author</strong>
                </p>
            }
            @if (Model.AverageRating > 0)
            {
                <div class="d-flex align-items-center">
                    <span class="text-warning fs-5">@Model.RatingStars</span>
                    <span class="ms-2 text-muted">(@Model.ReviewCount nhận xét)</span>
                </div>
            }
        </div>

        <!-- PRICING -->
        <div class="card mb-3">
            <div class="card-body">
                @if (Model.HasDiscount)
                {
                    <div class="mb-2">
                        <span class="text-decoration-line-through text-muted fs-5">@Model.OriginalPrice?.ToString("N0") VND</span>
                        @if (Model.DiscountPercent.HasValue)
                        {
                            <span class="badge bg-danger ms-2">Giảm @Model.DiscountPercent%</span>
                        }
                    </div>
                }
                <h2 class="text-danger mb-0">@Model.Price.ToString("N0") VND</h2>
                @if (Model.HasDiscount && Model.OriginalPrice.HasValue)
                {
                    <small class="text-success">Tiết kiệm: @((Model.OriginalPrice.Value - Model.Price).ToString("N0")) VND</small>
                }
            </div>
        </div>

        <!-- SHORT DESCRIPTION -->
        @if (!string.IsNullOrEmpty(Model.ShortDescription))
        {
            <div class="alert alert-light">
                <i class="bi bi-info-circle"></i> @Model.ShortDescription
            </div>
        }

        <!-- STOCK STATUS -->
        <div class="mb-3">
            <h5 class="mb-2">Tình trạng:</h5>
            @if (Model.IsOutOfStock)
            {
                <span class="badge bg-danger fs-6">
                    <i class="bi bi-x-circle"></i> Hết hàng
                </span>
            }
            else if (Model.IsLowStock)
            {
                <span class="badge bg-warning text-dark fs-6">
                    <i class="bi bi-exclamation-triangle"></i> Chỉ còn @Model.Stock sản phẩm
                </span>
            }
            else
            {
                <span class="badge bg-success fs-6">
                    <i class="bi bi-check-circle"></i> Còn hàng (@Model.Stock sản phẩm)
                </span>
            }
        </div>

        <!-- ADD TO CART -->
        @if (Model.IsAvailable && !Model.IsOutOfStock)
        {
            <form asp-area="" asp-controller="Cart" asp-action="AddToCart" method="get" class="mb-3">
                <input type="hidden" name="productId" value="@Model.ProductId" />
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label">Số lượng:</label>
                        <input type="number" name="quantity" value="1" min="1" max="@Model.Stock" 
                               class="form-control" style="width:100px;" 
                               title="Số lượng (tối đa @Model.Stock)" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="bi bi-cart-x"></i> Không thể đặt hàng
            </button>
        }

        <div class="mt-3">
            <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>

<!-- DETAILED INFORMATION -->
<div class="row mt-4">
    <div class="col-md-12">
        <ul class="nav nav-tabs" id="productTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">
                    <i class="bi bi-file-text"></i> Mô tả
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button" role="tab">
                    <i class="bi bi-info-circle"></i> Thông tin chi tiết
                </button>
            </li>
        </ul>
        <div class="tab-content p-3 border border-top-0" id="productTabsContent">
            <!-- MÔ TẢ -->
            <div class="tab-pane fade show active" id="description" role="tabpanel">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p style="white-space: pre-line;">@Model.Description</p>
                }
                else
                {
                    <p class="text-muted">Chưa có mô tả chi tiết.</p>
                }
            </div>
            
            <!-- THÔNG TIN CHI TIẾT -->
            <div class="tab-pane fade" id="specs" role="tabpanel">
                <table class="table table-bordered">
                    <tbody>
                        @if (!string.IsNullOrEmpty(Model.Author))
                        {
                            <tr>
                                <th style="width: 200px;">Tác giả</th>
                                <td>@Model.Author</td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.ISBN))
                        {
                            <tr>
                                <th>Mã ISBN</th>
                                <td>@Model.ISBN</td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.Publisher))
                        {
                            <tr>
                                <th>Nhà xuất bản</th>
                                <td>@Model.Publisher</td>
                            </tr>
                        }
                        @if (Model.PublicationYear.HasValue)
                        {
                            <tr>
                                <th>Năm xuất bản</th>
                                <td>@Model.PublicationYear</td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.Language))
                        {
                            <tr>
                                <th>Ngôn ngữ</th>
                                <td>@Model.Language</td>
                            </tr>
                        }
                        @if (Model.PageCount.HasValue)
                        {
                            <tr>
                                <th>Số trang</th>
                                <td>@Model.PageCount</td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.CoverType))
                        {
                            <tr>
                                <th>Hình thức bìa</th>
                                <td>@Model.CoverType</td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.Dimensions))
                        {
                            <tr>
                                <th>Kích thước</th>
                                <td>@Model.Dimensions cm</td>
                            </tr>
                        }
                        @if (Model.Weight.HasValue)
                        {
                            <tr>
                                <th>Trọng lượng</th>
                                <td>@Model.Weight gram</td>
                            </tr>
                        }
                        <tr>
                            <th>Danh mục</th>
                            <td>@(Model.Category?.CategoryName ?? "-")</td>
                        </tr>
                        @if (Model.SoldCount > 0)
                        {
                            <tr>
                                <th>Đã bán</th>
                                <td><span class="badge bg-info">@Model.SoldCount cuốn</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
