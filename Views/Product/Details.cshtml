@model HSU.PTWeb.AnhPH.BookStore.Models.Product

@{
    ViewData["Title"] = "Chi tiết sách";
}

<h2>@Model.ProductName</h2>
<div class="row">
    <div class="col-md-4">
        <img src="~/images/@(Model.ImageUrl ?? "products/placeholder.png")" class="img-fluid" style="object-fit:cover;" />
    </div>
    <div class="col-md-8">
        <p>@Model.Description</p>
        <p class="fw-bold text-danger">Giá: @Model.Price.ToString("N0") VND</p>
        <form asp-controller="Cart" asp-action="AddToCart" method="post">
            <input type="hidden" name="productId" value="@Model.ProductId" />
            <div class="mb-3" style="width:120px;">
                <label class="form-label">Số lượng</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" />
            </div>
            <button class="btn btn-primary">Thêm vào giỏ</button>
        </form>
    </div>
</div>
