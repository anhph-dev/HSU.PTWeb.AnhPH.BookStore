@model IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentSearch = ViewData["Search"] as string ?? "";
    var currentCategory = ViewData["CategoryId"] != null ? (int)ViewData["CategoryId"] : 0;
    var categories = ViewData["Categories"] as IEnumerable<HSU.PTWeb.AnhPH.BookStore.Models.Category> ?? Enumerable.Empty<HSU.PTWeb.AnhPH.BookStore.Models.Category>();
}

<h2>Quản lý sản phẩm</h2>

<!-- Form tìm kiếm và lọc -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="search" name="search" value="@currentSearch" class="form-control" placeholder="Tìm theo tên sách..." />
    </div>
    <div class="col-md-3">
        <select name="categoryId" class="form-select">
            <option value="0">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.CategoryId" selected="@(c.CategoryId == currentCategory)">@c.CategoryName</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100">Lọc</button>
    </div>
    <div class="col-md-3 text-end">
        <a asp-action="CreateProduct" class="btn btn-success w-100">Tạo sản phẩm mới</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ảnh</th>
            <th>Tên</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Kho</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><img src="~/images/@(p.ImageUrl ?? "products/placeholder.png")" style="width:60px;object-fit:cover;" /></td>
                <td>@p.ProductName</td>
                <td>@(p.Category?.CategoryName ?? "-")</td>
                <td>@p.Price.ToString("N0") VND</td>
                <td>@p.Stock</td>
                <td>
                    <a asp-action="EditProduct" asp-route-id="@p.ProductId" class="btn btn-sm btn-primary">Sửa</a>
                    <a asp-action="DeleteProduct" asp-route-id="@p.ProductId" class="btn btn-sm btn-danger" onclick="return confirm('Xóa sản phẩm này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Products"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)">«</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Products"
                       asp-route-page="@i"
                       asp-route-search="@currentSearch"
                       asp-route-categoryId="@(currentCategory)">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Products"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@currentSearch"
                   asp-route-categoryId="@(currentCategory)">»</a>
            </li>
        </ul>
    </nav>
}
