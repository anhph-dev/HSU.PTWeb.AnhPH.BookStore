@model HSU.PTWeb.AnhPH.BookStore.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2>Chi tiết đơn hàng #@Model.OrderId</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <p><strong>Người đặt:</strong> @(Model.User?.FullName ?? "-")</p>
        <p><strong>Email:</strong> @(Model.User?.Email ?? "-")</p>
    </div>
    <div class="col-md-6">
        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("g")</p>
        <p><strong>Trạng thái:</strong> <span class="badge bg-info">@Model.Status</span></p>
        <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") VND</span></p>
    </div>
</div>

<h4>Sản phẩm trong đơn</h4>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Đơn giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model.OrderDetails)
        {
            <tr>
                <td>@(d.Product?.ProductName ?? "-")</td>
                <td>@d.UnitPrice.ToString("N0") VND</td>
                <td>@d.Quantity</td>
                <td>@(d.UnitPrice * d.Quantity).ToString("N0") VND</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
            <td><strong>@Model.TotalAmount.ToString("N0") VND</strong></td>
        </tr>
    </tfoot>
</table>

<a asp-action="Orders" class="btn btn-secondary">Quay lại danh sách</a>
