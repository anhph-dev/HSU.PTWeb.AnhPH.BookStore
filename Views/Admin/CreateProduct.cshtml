@model HSU.PTWeb.AnhPH.BookStore.Models.Product

@{
    ViewData["Title"] = "Tạo sản phẩm";
}

<h2>Tạo sản phẩm</h2>

<form asp-action="CreateProduct" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label>Tiêu đề</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Mô tả</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Danh mục</label>
        <select asp-for="CategoryId" class="form-control">
            <option value="">-- Chọn --</option>
            @foreach (var c in (List<HSU.PTWeb.AnhPH.BookStore.Models.Category>)ViewData["Categories"])
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Hình</label>
        <input type="file" name="imageFile" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
</form>
