@model HSU.PTWeb.AnhPH.BookStore.Models.Product

@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<h2>S?a s?n ph?m</h2>

<form asp-action="EditProduct" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ProductId" />
    <div class="mb-3">
        <label class="form-label">Tên sách</label>
        <input asp-for="ProductName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Giá</label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Danh mục</label>
        <select asp-for="CategoryId" class="form-control">
            <option value="">-- Ch?n --</option>
            @foreach (var c in (List<HSU.PTWeb.AnhPH.BookStore.Models.Category>)ViewData["Categories"])
            {
                <option value="@c.CategoryId" selected="@(c.CategoryId==Model.CategoryId)">@c.CategoryName</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Hình ?nh</label>
        <input type="file" name="imageFile" class="form-control" />
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="~/images/@Model.ImageUrl" style="height:120px;margin-top:10px;object-fit:cover;" />
        }
    </div>
    <button class="btn btn-primary">Lưu</button>
</form>
