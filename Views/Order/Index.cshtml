@model List<HSU.PTWeb.AnhPH.BookStore.ViewModels.OrderListItemViewModel>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var currentPage   = (int)(ViewData["Page"] ?? 1);
    var totalPages    = (int)(ViewData["TotalPages"] ?? 1);
    var currentStatus = ViewData["Status"] as string ?? "";
    var fromDate      = ViewData["FromDate"] as string ?? "";
    var toDate        = ViewData["ToDate"] as string ?? "";
    var statuses      = new[] { "Pending", "Processing", "Shipped", "Completed", "Cancelled" };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-bag-check"></i> Đơn hàng của tôi</h4>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-shop"></i> Tiếp tục mua sắm
    </a>
</div>

{{-- Bộ lọc --}}
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">-- Tất cả trạng thái --</option>
                    @foreach (var s in statuses)
                    {
                        <option value="@s" selected="@(currentStatus == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" name="fromDate" value="@fromDate"
                       class="form-control form-control-sm" placeholder="Từ ngày" />
            </div>
            <div class="col-md-3">
                <input type="date" name="toDate" value="@toDate"
                       class="form-control form-control-sm" placeholder="Đến ngày" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-filter"></i> Lọc
                </button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-shop"></i> Mua sắm ngay
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#Đơn</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var badge = o.Status switch
                        {
                            "Completed"  => "bg-success",
                            "Shipped"    => "bg-info",
                            "Processing" => "bg-warning text-dark",
                            "Cancelled"  => "bg-secondary",
                            _            => "bg-light text-dark border"
                        };
                        <tr>
                            <td><strong>#@o.OrderId</strong></td>
                            <td class="text-muted small">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-danger">@o.TotalAmount.ToString("N0") đ</td>
                            <td>
                                <span class="badge @(o.Status == "Completed" || o.Status == "Shipped" ? "bg-success" : "bg-warning text-dark")">
                                    @(o.Status == "Completed" || o.Status == "Shipped" ? "Đã thanh toán" : "Chờ thanh toán")
                                </span>
                            </td>
                            <td><span class="badge @badge">@o.Status</span></td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@o.OrderId"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-status="@currentStatus"
                       asp-route-fromDate="@fromDate"
                       asp-route-toDate="@toDate">←</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-status="@currentStatus"
                           asp-route-fromDate="@fromDate"
                           asp-route-toDate="@toDate">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-status="@currentStatus"
                       asp-route-fromDate="@fromDate"
                       asp-route-toDate="@toDate">→</a>
                </li>
            </ul>
        </nav>
    }
}
