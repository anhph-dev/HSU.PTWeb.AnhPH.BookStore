@model List<HSU.PTWeb.AnhPH.BookStore.ViewModels.OrderListItemViewModel>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var currentPage = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var currentStatus = ViewData["Status"] as string ?? "";
    var fromDate = ViewData["FromDate"] as string ?? "";
    var toDate = ViewData["ToDate"] as string ?? "";
}

<h2>Đơn hàng của tôi</h2>

<!-- Form lọc -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="Mới" selected="@(currentStatus == "Mới")">Mới</option>
            <option value="Đã vận chuyển" selected="@(currentStatus == "Đã vận chuyển")">Đã vận chuyển</option>
            <option value="Đã thanh toán" selected="@(currentStatus == "Đã thanh toán")">Đã thanh toán</option>
        </select>
    </div>
    <div class="col-md-3">
        <input type="date" name="fromDate" value="@fromDate" class="form-control" placeholder="Từ ngày" />
    </div>
    <div class="col-md-3">
        <input type="date" name="toDate" value="@toDate" class="form-control" placeholder="Đến ngày" />
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary w-100">Lọc</button>
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày</th>
                <th>Tổng</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.OrderId</td>
                    <td>@o.OrderDate.ToString("g")</td>
                    <td>@o.TotalAmount.ToString("N0") VND</td>
                    <td><span class="badge bg-info">@o.Status</span></td>
                    <td><a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-primary">Xem chi tiết</a></td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-status="@currentStatus"
                       asp-route-fromDate="@fromDate"
                       asp-route-toDate="@toDate">«</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-status="@currentStatus"
                           asp-route-fromDate="@fromDate"
                           asp-route-toDate="@toDate">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-status="@currentStatus"
                       asp-route-fromDate="@fromDate"
                       asp-route-toDate="@toDate">»</a>
                </li>
            </ul>
        </nav>
    }
}
