@model List<HSU.PTWeb.AnhPH.BookStore.ViewModels.OrderListItemViewModel>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var currentPage   = (int)(ViewData["Page"] ?? 1);
    var totalPages    = (int)(ViewData["TotalPages"] ?? 1);
    var currentStatus = ViewData["Status"] as string ?? "";
    var fromDate      = ViewData["FromDate"] as string ?? "";
    var toDate        = ViewData["ToDate"] as string ?? "";
    var statuses      = new[] { "Pending", "Processing", "Shipped", "Completed", "Cancelled" };
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h3 class="mb-0 fw-bold text-primary"><i class="bi bi-bag-check me-2"></i> Đơn hàng của tôi</h3>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary shadow-sm">
        <i class="bi bi-shop"></i> Tiếp tục mua sắm
    </a>
</div>

<!-- Bộ lọc -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-muted small mb-1">Trạng thái đơn hàng</label>
                <select name="status" class="form-select border-0 shadow-sm">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var s in statuses)
                    {
                        var displayStatus = s switch {
                            "Pending" => "Chờ xử lý",
                            "Processing" => "Đang xử lý",
                            "Shipped" => "Đang giao hàng",
                            "Completed" => "Đã hoàn thành",
                            "Cancelled" => "Đã hủy",
                            _ => s
                        };
                        <option value="@s" selected="@(currentStatus == s ? "selected" : null)">@displayStatus</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small mb-1">Từ ngày</label>
                <input type="date" name="fromDate" value="@fromDate" class="form-control border-0 shadow-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small mb-1">Đến ngày</label>
                <input type="date" name="toDate" value="@toDate" class="form-control border-0 shadow-sm" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-filter"></i> Lọc đơn hàng
                </button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body text-center py-5">
            <i class="bi bi-bag-x text-secondary opacity-50" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3 mb-3">Bạn chưa có đơn hàng nào</h4>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary px-4 py-2 mt-2 shadow-sm">
                Khám phá sách ngay <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">MÃ ĐƠN</th>
                        <th>NGÀY ĐẶT</th>
                        <th>TRẠNG THÁI</th>
                        <th>TỔNG TIỀN</th>
                        <th class="text-end pe-4">CHI TIẾT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var badgeClass = o.Status switch
                        {
                            "Completed"  => "bg-success bg-opacity-10 text-success border border-success-subtle",
                            "Shipped"    => "bg-info bg-opacity-10 text-info border border-info-subtle",
                            "Processing" => "bg-primary bg-opacity-10 text-primary border border-primary-subtle",
                            "Pending"    => "bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle",
                            "Cancelled"  => "bg-danger bg-opacity-10 text-danger border border-danger-subtle",
                            _            => "bg-light text-dark border"
                        };
                        
                        var badgeText = o.Status switch {
                            "Pending" => "Chờ xử lý",
                            "Processing" => "Đang xử lý",
                            "Shipped" => "Đang giao",
                            "Completed" => "Đã nhận",
                            "Cancelled" => "Đã hủy",
                            _ => o.Status
                        };

                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">#@o.OrderId</span>
                            </td>
                            <td>
                                <span class="text-muted"><i class="bi bi-calendar-event me-2"></i>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2 @badgeClass">
                                    @badgeText
                                </span>
                            </td>
                            <td>
                                <span class="fw-bold text-danger fs-6">@o.TotalAmount.ToString("N0") đ</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                    Xem chi tiết <i class="bi bi-chevron-right ms-1 small"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (totalPages > 1)
        {
            <div class="card-footer bg-white border-top-0 pt-4 pb-3">
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-status="@currentStatus"
                               asp-route-fromDate="@fromDate"
                               asp-route-toDate="@toDate">Trước</a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-status="@currentStatus"
                                   asp-route-fromDate="@fromDate"
                                   asp-route-toDate="@toDate">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-status="@currentStatus"
                               asp-route-fromDate="@fromDate"
                               asp-route-toDate="@toDate">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
}
