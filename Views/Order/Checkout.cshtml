@model HSU.PTWeb.AnhPH.BookStore.ViewModels.CheckoutViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Thanh toán";
    var cart = ViewBag.Cart as List<HSU.PTWeb.AnhPH.BookStore.Models.CartItem> ?? new List<HSU.PTWeb.AnhPH.BookStore.Models.CartItem>();
    var total = ViewBag.Total != null ? (decimal)ViewBag.Total : 0;
    var cities = ViewBag.Cities as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold">Thanh toán đơn hàng</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
            </ol>
        </nav>
    </div>
</div>

@if (!cart.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-cart-x"></i> Giỏ hàng của bạn đang trống.
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-shop"></i> Tiếp tục mua sắm
    </a>
}
else
{
    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-truck text-primary"></i> Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Checkout" method="post" id="checkoutForm">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" placeholder="Nhập địa chỉ email" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="RecipientName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="RecipientName" class="form-control" placeholder="Nhập họ và tên người nhận" required />
                                <span asp-validation-for="RecipientName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="PhoneNumber" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại đăng ký nhận hàng" required pattern="[0-9]{10,11}" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="CityId" class="form-label">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                                <select asp-for="CityId" class="form-select" id="citySelect" required>
                                    <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                    @foreach (var city in cities)
                                    {
                                        <option value="@city.Value">@city.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="CityId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="WardId" class="form-label">Phường / Xã <span class="text-danger">*</span></label>
                                <select asp-for="WardId" class="form-select" id="wardSelect" required disabled>
                                    <option value="">-- Chọn Phường/Xã --</option>
                                </select>
                                <span asp-validation-for="WardId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="ShippingAddress" class="form-label">Địa chỉ giao hàng (Số nhà, Đường) <span class="text-danger">*</span></label>
                                <textarea asp-for="ShippingAddress" class="form-control" rows="2" placeholder="Nhập địa chỉ nhận hàng chi tiết" required></textarea>
                                <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="PaymentMethod" class="form-label">Phương thức thanh toán <span class="text-danger">*</span></label>
                                <select asp-for="PaymentMethod" class="form-select" required>
                                    <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                                    <option value="BankTransfer">Chuyển khoản ngân hàng</option>
                                    <option value="VNPay">Thanh toán qua VNPay</option>
                                </select>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label asp-for="Notes" class="form-label">Ghi chú (Tùy chọn)</label>
                                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Ghi chú về thời gian hoặc địa điểm nhận hàng"></textarea>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-receipt text-primary"></i> Tóm tắt đơn hàng</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in cart)
                        {
                            var lineTotal = item.Price * item.Quantity;
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div class="d-flex align-items-center">
                                    <img src="~/images/@(item.ImageUrl ?? "products/placeholder.svg")"
                                         style="width:50px;height:50px;object-fit:cover;"
                                         class="me-3 rounded shadow-sm"
                                         onerror="this.src='/images/products/placeholder.svg'" />
                                    <div>
                                        <h6 class="mb-0 text-truncate" style="max-width: 180px;" title="@item.ProductName">@item.ProductName</h6>
                                        <small class="text-muted">SL: @item.Quantity</small>
                                    </div>
                                </div>
                                <span class="fw-bold">@lineTotal.ToString("N0") đ</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-light py-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fs-5 text-muted">Tổng cộng:</span>
                        <span class="fs-4 fw-bold text-danger">@total.ToString("N0") VNĐ</span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" id="btnPlaceOrder" class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle me-1"></i> Xác nhận đặt hàng
                        </button>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại giỏ hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const citySelect = document.getElementById('citySelect');
        const wardSelect = document.getElementById('wardSelect');

        const preselectedCity = '@(Model?.CityId?.ToString() ?? "")';
        const preselectedWard = '@(Model?.WardId?.ToString() ?? "")';

        async function loadWards(cityId, selectedWard) {
            wardSelect.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
            wardSelect.disabled = true;

            if (!cityId) {
                return;
            }

            try {
                const response = await fetch('@Url.Action("GetWardsByCity", "Order")?cityId=' + cityId);
                if (!response.ok) return;

                const wards = await response.json();
                wards.forEach(w => {
                    const opt = document.createElement('option');
                    opt.value = w.wardId;
                    opt.textContent = w.wardName;
                    if (String(w.wardId) === String(selectedWard)) {
                        opt.selected = true;
                    }
                    wardSelect.appendChild(opt);
                });

                wardSelect.disabled = false;
            } catch {
                wardSelect.disabled = true;
            }
        }

        citySelect.addEventListener('change', function () {
            loadWards(citySelect.value, '');
        });

        document.addEventListener('DOMContentLoaded', function () {
            if (preselectedCity) {
                citySelect.value = preselectedCity;
                loadWards(preselectedCity, preselectedWard);
            }
        });

        document.getElementById('btnPlaceOrder')?.addEventListener('click', function () {
            const form = document.getElementById('checkoutForm');
            if (!form) return;
            if (form.requestSubmit) {
                form.requestSubmit();
            } else {
                form.submit();
            }
        });
    </script>
}
