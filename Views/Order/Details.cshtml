@model HSU.PTWeb.AnhPH.BookStore.ViewModels.OrderDetailsViewModel

@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderId}";

    var statusClass = Model.Status switch
    {
        "Completed" => "bg-success bg-opacity-10 text-success border border-success-subtle",
        "Shipping" => "bg-secondary bg-opacity-10 text-secondary-emphasis border border-secondary-subtle",
        "Confirmed" => "bg-primary bg-opacity-10 text-primary border border-primary-subtle",
        "Pending" => "bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle",
        "Cancelled" => "bg-danger bg-opacity-10 text-danger border border-danger-subtle",
        _ => "bg-light text-dark border"
    };

    var statusText = Model.Status switch
    {
        "Pending" => "Chờ xử lý",
        "Confirmed" => "Đã xác nhận",
        "Shipping" => "Đang giao",
        "Completed" => "Đã hoàn thành",
        "Cancelled" => "Đã hủy",
        _ => Model.Status
    };

    var paymentText = Model.PaymentMethod switch
    {
        "COD" => "Thanh toán khi nhận hàng (COD)",
        "BankTransfer" => "Chuyển khoản ngân hàng",
        "VNPay" => "Thanh toán qua VNPay",
        _ => Model.PaymentMethod
    };

    var paymentClass = Model.PaymentStatus == "Paid"
        ? "bg-success bg-opacity-10 text-success border border-success-subtle"
        : Model.PaymentStatus == "Failed"
            ? "bg-danger bg-opacity-10 text-danger border border-danger-subtle"
            : "bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle";

    var paymentStatusText = Model.PaymentStatus switch
    {
        "Paid" => "Đã thanh toán",
        "Failed" => "Thanh toán thất bại",
        _ => "Chờ thanh toán"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h3 class="mb-0 fw-bold text-primary"><i class="bi bi-receipt-cutoff me-2"></i> Chi tiết đơn hàng #@Model.OrderId</h3>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="mb-4">
    <span class="badge rounded-pill px-3 py-2 @statusClass">@statusText</span>
</div>

<div class="row">
    @* Danh sách sản phẩm *@
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="card-title mb-0"><i class="bi bi-bag text-primary"></i> Sản phẩm đã mua</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4">Tên sách</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@item.ProductName</td>
                                <td class="text-center">x@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                <td class="text-end pe-4 fw-bold">@item.LineTotal.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end pe-4 fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    @* Thông tin giao hàng và thanh toán *@
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="card-title mb-0"><i class="bi bi-truck text-primary"></i> Giao hàng</h5>
            </div>
            <div class="card-body">
                <p class="mb-1 fw-semibold">@Model.RecipientName</p>
                <p class="mb-1 text-muted"><i class="bi bi-telephone me-1"></i>@Model.PhoneNumber</p>
                <p class="mb-1 text-muted"><i class="bi bi-envelope me-1"></i>@Model.Email</p>
                <p class="mb-0 text-muted"><i class="bi bi-geo-alt me-1"></i>@Model.ShippingAddress, @(string.IsNullOrWhiteSpace(Model.Ward) ? "" : Model.Ward + ", ")@Model.City</p>

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <hr class="my-3" />
                    <p class="mb-0 text-muted small"><i class="bi bi-chat-text me-1"></i>@Model.Notes</p>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="card-title mb-0"><i class="bi bi-credit-card text-primary"></i> Thanh toán</h5>
            </div>
            <div class="card-body">
                <p class="mb-2"><span class="text-muted">Phương thức:</span> <strong>@paymentText</strong></p>
                <p class="mb-2">
                    <span class="text-muted">Trạng thái:</span>
                    <span class="badge rounded-pill px-3 py-2 @paymentClass">@paymentStatusText</span>
                </p>
                <hr class="my-3" />
                <p class="mb-0 text-muted small"><i class="bi bi-calendar3 me-1"></i>Đặt lúc: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div>
