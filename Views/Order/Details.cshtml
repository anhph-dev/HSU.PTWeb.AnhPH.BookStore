@model HSU.PTWeb.AnhPH.BookStore.ViewModels.OrderDetailsViewModel
@{ ViewData["Title"] = $"Đơn hàng #{Model.OrderId}"; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Đơn hàng của tôi
    </a>
    <h4 class="mb-0">
        <i class="bi bi-receipt"></i> Đơn hàng #@Model.OrderId
    </h4>
    @{
        var badge = Model.Status switch
        {
            "Completed"  => "bg-success",
            "Shipped"    => "bg-info",
            "Processing" => "bg-warning text-dark",
            "Cancelled"  => "bg-secondary",
            _            => "bg-light text-dark border"
        };
    }
    <span class="badge @badge fs-6">@Model.Status</span>
</div>

<div class="row">
    {{-- Danh sách sách đã mua --}}
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-bag"></i> Sách đã mua</h6></div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tên sách</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td><strong>@item.ProductName</strong></td>
                                <td class="text-center">x@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@item.LineTotal.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold text-danger fs-5">
                                @Model.TotalAmount.ToString("N0") đ
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    {{-- Thông tin giao hàng & thanh toán --}}
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-truck"></i> Thông tin giao hàng</h6></div>
            <div class="card-body">
                <p class="mb-1"><strong>@Model.RecipientName</strong></p>
                <p class="mb-1 text-muted"><i class="bi bi-telephone"></i> @Model.PhoneNumber</p>
                <p class="mb-1 text-muted"><i class="bi bi-envelope"></i> @Model.Email</p>
                <p class="mb-0 text-muted">
                    <i class="bi bi-geo-alt"></i>
                    @Model.ShippingAddress,
                    @(string.IsNullOrEmpty(Model.Ward) ? "" : Model.Ward + ", ")
                    @(string.IsNullOrEmpty(Model.District) ? "" : Model.District + ", ")
                    @Model.City
                </p>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr class="my-2" />
                    <p class="mb-0 text-muted small">
                        <i class="bi bi-chat-text"></i> @Model.Notes
                    </p>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-credit-card"></i> Thanh toán</h6></div>
            <div class="card-body">
                <p class="mb-1">
                    <span class="text-muted">Phương thức:</span>
                    <strong>@Model.PaymentMethod</strong>
                </p>
                <p class="mb-1">
                    <span class="text-muted">Trạng thái:</span>
                    @{
                        var payBadge = Model.PaymentStatus == "Paid" ? "bg-success" : "bg-warning text-dark";
                    }
                    <span class="badge @payBadge">@Model.PaymentStatus</span>
                </p>
                <hr class="my-2" />
                <p class="mb-1 text-muted small">
                    <i class="bi bi-calendar3"></i> Đặt lúc: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>
        </div>
    </div>
</div>
