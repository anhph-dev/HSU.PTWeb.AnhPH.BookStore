@model HSU.PTWeb.AnhPH.BookStore.ViewModels.RegisterViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Đăng ký";
    var cities = ViewBag.RegisterCities as List<SelectListItem> ?? new List<SelectListItem>();
    var wardByCityJson = ViewBag.RegisterWardByCityJson as string ?? "{}";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-white text-center py-4 border-bottom-0">
                <h3 class="mb-0 fw-bold text-primary"><i class="bi bi-person-plus"></i> Đăng ký tài khoản</h3>
            </div>
            <div class="card-body p-4 pt-0">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label text-muted fw-semibold">Họ và tên</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-person"></i></span>
                            <input asp-for="FullName" class="form-control border-start-0 ps-0" placeholder="Nguyễn Văn A" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label text-muted fw-semibold">Email (Tên đăng nhập)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-envelope"></i></span>
                            <input asp-for="UserName" type="email" class="form-control border-start-0 ps-0" placeholder="email@example.com" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label text-muted fw-semibold">Mật khẩu</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label text-muted fw-semibold">Xác nhận mật khẩu</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label text-muted fw-semibold">Số điện thoại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-telephone"></i></span>
                            <input asp-for="PhoneNumber" class="form-control border-start-0 ps-0" placeholder="0912345678" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label text-muted fw-semibold">Địa chỉ</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Address" class="form-control border-start-0 ps-0" placeholder="Số nhà, tên đường..." />
                        </div>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CityId" class="form-label text-muted fw-semibold"></label>
                        <select asp-for="CityId" class="form-select text-dark" id="citySelect" required>
                            <option value="">-- Chọn Tỉnh/Thành phố --</option>
                            @foreach (var city in cities)
                            {
                                <option value="@city.Value">@city.Text</option>
                            }
                        </select>
                        <span asp-validation-for="CityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="WardId" class="form-label text-muted fw-semibold"></label>
                        <select asp-for="WardId" class="form-select" id="wardSelect" required>
                            <option value="">-- Chọn Phường/Xã --</option>
                        </select>
                        <span asp-validation-for="WardId" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-semibold shadow-sm">Đăng ký</button>
                    </div>
                </form>

            </div>
            <div class="card-footer bg-light text-center py-3 border-top-0 rounded-bottom-3">
                <span class="text-muted">Đã có tài khoản?</span>
                <a asp-action="Login" class="text-decoration-none fw-semibold">Đăng nhập</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const wardByCity = @Html.Raw(wardByCityJson);

        const citySelect = document.getElementById('citySelect');
        const wardSelect = document.getElementById('wardSelect');

        function bindWards() {
            const selectedCity = Number(citySelect.value);
            const currentWard = '@(Model?.WardId?.ToString() ?? "")';

            wardSelect.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';

            if (!selectedCity || !wardByCity[selectedCity]) return;

            wardByCity[selectedCity].forEach(w => {
                const opt = document.createElement('option');
                opt.value = w.value;
                opt.textContent = w.text;
                if (currentWard === String(w.value)) opt.selected = true;
                wardSelect.appendChild(opt);
            });
        }

        citySelect.addEventListener('change', bindWards);
        bindWards();
    </script>
}
