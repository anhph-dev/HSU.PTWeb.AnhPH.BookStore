@model HSU.PTWeb.AnhPH.BookStore.ViewModels.ProfileViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thông tin cá nhân";
    var cities = ViewData["ProfileCities"] as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="container">
    <div class="row mt-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-circle"></i> Thông tin cá nhân</h5>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@e.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <form asp-action="Profile" method="post">

                        <h6 class="text-muted mb-3 border-bottom pb-2">Thông tin cơ bản</h6>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email (không thể thay đổi)</label>
                            <input type="text" value="@Model.Email" class="form-control bg-light" readonly />
                        </div>

                        <div class="row">
                            <div class="col-md-7 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <h6 class="text-muted mb-3 border-bottom pb-2 mt-2">Địa chỉ giao hàng mặc định</h6>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <input asp-for="Address" class="form-control" placeholder="Số nhà, tên đường..." />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CityId" class="form-label fw-bold"></label>
                            <select asp-for="CityId" class="form-select" id="citySelect">
                                <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                @foreach (var city in cities)
                                {
                                    <option value="@city.Value">@city.Text</option>
                                }
                            </select>
                            <span asp-validation-for="CityId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="WardId" class="form-label fw-bold"></label>
                            <select asp-for="WardId" class="form-select" id="wardSelect" disabled>
                                <option value="">-- Chọn Phường/Xã --</option>
                            </select>
                            <span asp-validation-for="WardId" class="text-danger small"></span>
                        </div>

                        <h6 class="text-muted mb-3 border-bottom pb-2 mt-2">Đổi mật khẩu <small class="text-muted fw-normal">(để trống nếu không muốn đổi)</small></h6>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewPassword" class="form-label fw-bold"></label>
                                <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Lưu thay đổi
                            </button>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header"><h6 class="mb-0">Thông tin tài khoản</h6></div>
                <div class="card-body">
                    <p class="mb-1"><strong>Vai trò:</strong>
                        <span class="badge @(Model.Role == "Admin" ? "bg-danger" : "bg-success")">@Model.Role</span>
                    </p>
                    <p class="mb-0 text-muted small">
                        <i class="bi bi-calendar3"></i> Thành viên từ @Model.CreatedDate.ToString("dd/MM/yyyy")
                    </p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header"><h6 class="mb-0">Liên kết nhanh</h6></div>
                <div class="list-group list-group-flush">
                    <a asp-controller="Order" asp-action="Index" class="list-group-item list-group-item-action">
                        <i class="bi bi-bag-check text-primary"></i> Đơn hàng của tôi
                    </a>
                    <a asp-controller="Cart" asp-action="Index" class="list-group-item list-group-item-action">
                        <i class="bi bi-cart3 text-warning"></i> Giỏ hàng
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="list-group-item list-group-item-action">
                        <i class="bi bi-books text-success"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const citySelect = document.getElementById('citySelect');
        const wardSelect = document.getElementById('wardSelect');

        const currentCityId = '@(Model?.CityId?.ToString() ?? "")';
        const currentWardId = '@(Model?.WardId?.ToString() ?? "")';

        async function loadWards(cityId, selectedWard) {
            wardSelect.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
            wardSelect.disabled = true;

            if (!cityId) {
                return;
            }

            try {
                const response = await fetch('@Url.Action("GetWardsByCity", "Account")?cityId=' + cityId);
                if (!response.ok) return;

                const wards = await response.json();
                wards.forEach(w => {
                    const opt = document.createElement('option');
                    opt.value = w.wardId;
                    opt.textContent = w.wardName;
                    if (String(w.wardId) === String(selectedWard)) {
                        opt.selected = true;
                    }
                    wardSelect.appendChild(opt);
                });

                wardSelect.disabled = false;
            } catch {
                wardSelect.disabled = true;
            }
        }

        citySelect.addEventListener('change', function () {
            loadWards(citySelect.value, '');
        });

        document.addEventListener('DOMContentLoaded', function () {
            if (currentCityId) {
                citySelect.value = currentCityId;
                loadWards(currentCityId, currentWardId);
            }
        });
    </script>
}
